{
  "name": "kkp-anwar-kpi",
  "version": "1.0.0",
  "description": "KKP Anwar KPI - Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "unset ELECTRON_RUN_AS_NODE && electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --mac --win --linux",
    "postbuild:mac": "cp dist/*.dmg ../public/downloads/ 2>/dev/null || true",
    "postbuild:win": "cp dist/*.exe ../public/downloads/ 2>/dev/null || true",
    "postbuild:linux": "cp dist/*.AppImage ../public/downloads/ 2>/dev/null || true"
  },
  "build": {
    "appId": "com.kkpanwar.kpi",
    "productName": "KKP Anwar KPI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Office"
    },
    "dmg": {
      "title": "KKP Anwar KPI",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "build/icon.png",
      "build/tray-icon.png"
    ],
    "asarUnpack": [
      "node_modules/sharp/**",
      "node_modules/@img/**"
    ]
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "sharp": "^0.33.2",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^24.9.1"
  }
}
